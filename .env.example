# KRONOS-WX Environment Configuration
# Copy this file to .env and fill in your values.

# ── Data storage paths ──────────────────────────────────────────────────────
# DATA_DIR=./data
# LOG_DIR=./logs

# ── Copernicus CDS API key (required for ERA5 reanalysis) ──────────────────
# Register at https://cds.climate.copernicus.eu/user/register
# Format: <UID>:<API-KEY>
# CDS_API_KEY=12345:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Case library date range ──────────────────────────────────────────────────
# CASE_LIBRARY_START_YEAR=1994
# CASE_LIBRARY_END_YEAR=2024

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Rate limiting (seconds between requests) ─────────────────────────────────
# MESONET_REQUEST_DELAY=1.1
# WYOMING_REQUEST_DELAY=2.0
