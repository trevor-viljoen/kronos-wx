# KRONOS-WX Environment Configuration
# Copy this file to .env and fill in your values.

# ── Data storage paths ──────────────────────────────────────────────────────
# DATA_DIR=./data
# LOG_DIR=./logs

# ── NWS API contact (required) ───────────────────────────────────────────────
# api.weather.gov requires a contact email in every request's User-Agent.
# Set this to your own email address. Without it, requests identify as
# "kronos-wx-operator" which may cause NWS to throttle or block the app.
# NWS_CONTACT_EMAIL=you@example.com

# ── Copernicus CDS API key (required for ERA5 reanalysis) ──────────────────
# Register at https://cds.climate.copernicus.eu/user/register
# Format: <UID>:<API-KEY>
# CDS_API_KEY=12345:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# CDSAPI_URL=https://cds.climate.copernicus.eu/api

# ── Web Push notifications ───────────────────────────────────────────────────
# VAPID contact URI sent to push services (mailto: or https: required).
# VAPID_CONTACT=mailto:you@example.com

# ── Case library date range ──────────────────────────────────────────────────
# CASE_LIBRARY_START_YEAR=1994
# CASE_LIBRARY_END_YEAR=2024

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Rate limiting (seconds between requests) ─────────────────────────────────
# MESONET_REQUEST_DELAY=1.1
# WYOMING_REQUEST_DELAY=2.0

# ── War Room Mode (Optional) ────────────────────────────────────────────────
# Integration with tablo-web for live media coverage.
# WAR_ROOM_ENABLED=false
# WAR_ROOM_TABLO_WEB_HOST=http://localhost:7070
# WAR_ROOM_KOCO_ID=your-channel-id
# WAR_ROOM_KFOR_ID=your-channel-id
# WAR_ROOM_KWTV_ID=your-channel-id
